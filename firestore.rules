rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function requestHasRole(role) {
      return request.resource.data.role == role;
    }

    function existingDataHasRole(role) {
      return resource.data.role == role;
    }

    function isTeacher() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function isStudent() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    // --- Rules ---

    // Rules for the 'users' collection
    match /users/{userId} {
      // Create:
      // 1. Any signed-in user can create their OWN user document.
      // 2. The data must have a name, email, and role.
      // 3. If the role is 'teacher', it must include a 6-char teacherCode.
      // 4. If the role is 'student', it must include a teacherId.
      allow create: if isSignedIn() && isOwner(userId)
                    && request.resource.data.name is string
                    && request.resource.data.email == request.auth.email
                    && (
                      (requestHasRole('teacher') && request.resource.data.teacherCode is string && request.resource.data.teacherCode.size() == 6) ||
                      (requestHasRole('student') && request.resource.data.teacherId is string)
                    );

      // Read:
      // 1. A user can read their own document.
      // 2. A teacher can read the document of their own students.
      allow read: if isSignedIn() && (isOwner(userId) || (isTeacher() && get(/databases/$(database)/documents/users/$(userId)).data.teacherId == request.auth.uid));

      // Update:
      // 1. A user can update their own document.
      // 2. They CANNOT change their role, email, or teacherCode after creation.
      allow update: if isSignedIn() && isOwner(userId)
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.email == resource.data.email
                    && request.resource.data.teacherCode == resource.data.teacherCode;

      // Delete: No one can delete user documents.
      allow delete: if false;
    }

    // Rules for the 'teacherCodes' collection
    match /teacherCodes/{code} {
      // A teacher can create a teacher code document if the teacherId in the new doc
      // matches their own UID. This is part of the signup transaction.
      allow create: if isSignedIn() && request.resource.data.teacherId == request.auth.uid;

      // No one can read, update, or delete teacher codes directly.
      allow read, update, delete: if false;
    }
    
    // Rules for 'content', 'assignments', 'assessments', 'submissions'
    // These are simplified for now and should be expanded as features are built.
    
    match /content/{contentId} {
      allow read, write: if isSignedIn() && isTeacher() && resource.data.teacherId == request.auth.uid;
      allow read: if isSignedIn() && isStudent() && resource.data.assignedStudentIds.hasAny([request.auth.uid]);
    }
    
    match /assignments/{assignmentId} {
       allow create: if isSignedIn() && isTeacher() && request.resource.data.teacherId == request.auth.uid;
       allow read: if isSignedIn() && (
                      (isStudent() && resource.data.studentId == request.auth.uid) ||
                      (isTeacher() && resource.data.teacherId == request.auth.uid)
                    );
       allow update, delete: if false;
    }
    
    match /assessments/{assessmentId} {
      allow create, update, delete: if isSignedIn() && isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow read: if isSignedIn() && (
                    (isTeacher() && resource.data.teacherId == request.auth.uid) ||
                    (isStudent() && resource.data.assignedStudentIds.hasAny([request.auth.uid]))
                  );
    }
    
    match /submissions/{submissionId} {
       allow create: if isSignedIn() && isStudent() && request.resource.data.studentId == request.auth.uid;
       allow read, update: if isSignedIn() && (
                              (isTeacher() && resource.data.teacherId == request.auth.uid) ||
                              (isStudent() && resource.data.studentId == request.auth.uid)
                            );
       allow delete: if false;
    }
  }
}
