
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isTeacher() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null && userDoc.data.role == 'teacher';
    }

    function isStudent() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null && userDoc.data.role == 'student';
    }

    // --- Rules for 'users' collection ---
    match /users/{userId} {
      // Create: Anyone can create their own user document during signup.
      allow create: if isSignedIn() && isOwner(userId);

      // Read:
      // 1. A user can read their own document.
      // 2. A teacher can read any user document. The app filters for students.
      allow read: if isSignedIn() && (isOwner(userId) || isTeacher());

      // Update:
      // 1. A user can update their own document.
      // 2. They CANNOT change their role or email after they are set.
      // 3. This allows the SignUpForm to fill in missing fields even if TranslationProvider created a partial doc.
      allow update: if isSignedIn() && isOwner(userId) &&
        (!('email' in resource.data) || request.resource.data.email == resource.data.email) &&
        (!('role' in resource.data) || request.resource.data.role == resource.data.role);
      
      // Delete: No one can delete user documents.
      allow delete: if false;
    }
    
    // --- Rules for Content & Submissions ---
    match /content/{contentId} {
      // Teacher who owns it can do anything.
      allow create, update, delete: if isSignedIn() && isTeacher() && request.resource.data.teacherId == request.auth.uid;
      // Teacher who owns it or created the assignment can read it.
      // Any student it's been assigned to can read it.
      allow read: if isSignedIn() && (
        (isTeacher() && resource.data.teacherId == request.auth.uid) ||
        (isStudent() && resource.data.assignedStudentIds.hasAny([request.auth.uid]))
      );
    }
    
    match /assignments/{assignmentId} {
       // A teacher can create an assignment.
       allow create: if isSignedIn() && isTeacher();
       // The assigned student or any teacher can read it.
       allow read: if isSignedIn() && (
                      (isStudent() && resource.data.studentId == request.auth.uid) ||
                      isTeacher()
                    );
       allow update, delete: if false;
    }
    
    match /assessments/{assessmentId} {
      // A teacher can create/manage assessments.
      allow create, update, delete: if isSignedIn() && isTeacher();
      // Any teacher or any assigned student can read it.
      allow read: if isSignedIn() && (
                    isTeacher() ||
                    (isStudent() && resource.data.assignedStudentIds.hasAny([request.auth.uid]))
                  );
    }
    
    match /submissions/{submissionId} {
       // A student can create their own submission.
       allow create: if isSignedIn() && isStudent() && request.resource.data.studentId == request.auth.uid;
       // The student who submitted it or any teacher can read/update it.
       allow read, update: if isSignedIn() && (
                              isTeacher() ||
                              (isStudent() && resource.data.studentId == request.auth.uid)
                            );
       allow delete: if false;
    }

  }
}
