
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function requestHasRole(role) {
      return request.resource.data.role == role;
    }

    function isTeacher() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function isStudent() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    // --- Rules for 'users' collection ---
    match /users/{userId} {
      // Create:
      // A user document can only be created as part of a specific transaction (teacher signup)
      // or if the student provides a valid teacherId or no teacherId.
      allow create: if (
        // Teacher signup: Must create a corresponding teacherCode document
        // This is handled by the rule on teacherCodes, which allows the transaction.
        requestHasRole('teacher') &&
        request.resource.data.name is string &&
        request.resource.data.email == request.auth.email &&
        request.resource.data.teacherCode is string && request.resource.data.teacherCode.size() == 6
      ) || (
        // Student signup:
        requestHasRole('student') &&
        request.resource.data.name is string &&
        request.resource.data.email == request.auth.email &&
        (
          // Case 1: Student provides a valid teacherId
          (
            request.resource.data.teacherId is string &&
            exists(/databases/$(database)/documents/users/$(request.resource.data.teacherId)) &&
            get(/databases/$(database)/documents/users/$(request.resource.data.teacherId)).data.role == 'teacher'
          ) ||
          // Case 2: Student does not provide a teacherId
          (
            request.resource.data.teacherId == null
          )
        )
      );

      // Read:
      // 1. A user can read their own document.
      // 2. A teacher can read the document of their own students.
      allow read: if isSignedIn() && (
        isOwner(userId) || 
        (isTeacher() && get(/databases/$(database)/documents/users/$(userId)).data.teacherId == request.auth.uid)
      );

      // Update:
      // 1. A user can update their own document.
      // 2. They CANNOT change their role or email after creation.
      // 3. Teachers CANNOT change their teacherCode.
      // 4. Students can set their teacherId ONCE if it is currently null.
      allow update: if isSignedIn() && isOwner(userId) &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.role == resource.data.role &&
        (resource.data.role == 'teacher' ? request.resource.data.teacherCode == resource.data.teacherCode : true) &&
        (resource.data.role == 'student' ?
            (
                (
                    resource.data.teacherId == null &&
                    request.resource.data.teacherId is string &&
                    exists(/databases/$(database)/documents/users/$(request.resource.data.teacherId)) &&
                    get(/databases/$(database)/documents/users/$(request.resource.data.teacherId)).data.role == 'teacher'
                ) ||
                (
                    request.resource.data.teacherId == resource.data.teacherId
                )
            )
            : true
        );

      // Delete: No one can delete user documents.
      allow delete: if false;
    }

    // --- Rules for 'teacherCodes' collection ---
    match /teacherCodes/{code} {
      // Allow creation only if the user making the request is the teacher being referenced.
      // This is the key to allowing the teacher signup transaction.
      allow create: if isSignedIn() && request.resource.data.teacherId == request.auth.uid;

      // No one can read, update, or delete teacher codes directly.
      allow read, update, delete: if false;
    }
    
    // --- Rules for Content & Submissions ---
    match /content/{contentId} {
      // Teacher who owns it can do anything.
      allow create, update, delete: if isSignedIn() && isTeacher() && request.resource.data.teacherId == request.auth.uid;
      // Teacher who owns it can read it.
      allow read: if isSignedIn() && isTeacher() && resource.data.teacherId == request.auth.uid;
      // Any student it's been assigned to can read it.
      allow read: if isSignedIn() && isStudent() && resource.data.assignedStudentIds.hasAny([request.auth.uid]);
    }
    
    match /assignments/{assignmentId} {
       // A teacher can create an assignment for their student.
       allow create: if isSignedIn() && isTeacher() && request.resource.data.teacherId == request.auth.uid;
       // The assigned student or the teacher can read it.
       allow read: if isSignedIn() && (
                      (isStudent() && resource.data.studentId == request.auth.uid) ||
                      (isTeacher() && resource.data.teacherId == request.auth.uid)
                    );
       allow update, delete: if false;
    }
    
    match /assessments/{assessmentId} {
      // A teacher can create/manage assessments.
      allow create, update, delete: if isSignedIn() && isTeacher() && request.resource.data.teacherId == request.auth.uid;
      // The teacher or any assigned student can read it.
      allow read: if isSignedIn() && (
                    (isTeacher() && resource.data.teacherId == request.auth.uid) ||
                    (isStudent() && resource.data.assignedStudentIds.hasAny([request.auth.uid]))
                  );
    }
    
    match /submissions/{submissionId} {
       // A student can create their own submission.
       allow create: if isSignedIn() && isStudent() && request.resource.data.studentId == request.auth.uid;
       // The student who submitted it or their teacher can read/update it.
       allow read, update: if isSignedIn() && (
                              (isTeacher() && resource.data.teacherId == request.auth.uid) ||
                              (isStudent() && resource.data.studentId == request.auth.uid)
                            );
       allow delete: if false;
    }

  }
}
